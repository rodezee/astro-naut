---
const basePrice = 100;
const discount = 0.20; // 20% off
const items = [
  { name: "Space Helmet", stock: 5 },
  { name: "Moon Boots", stock: 0 },
  { name: "Laser Blaster", stock: 12 }
];
---
<main>
  <h2>Space Supply Store</h2>
  <p>Today's Discount: <strong>{discount * 100}% off!</strong></p>
  
  <div class="grid">
    {items.map(item => `
      <div class="card">
        <h4>${item.name}</h4>
        <p>Original: $${basePrice}</p>
        <p class="sale">Sale Price: $${basePrice - (basePrice * discount)}</p>
        
        ${item.stock > 0 
          ? `<span class="in-stock">In Stock (${item.stock})</span>` 
          : `<span class="out-stock">Out of Stock</span>`
        }
      </div>
    `).join('')}
  </div>

<style>
  body { font-family: sans-serif; padding: 20px; color: #1e293b;}
  .grid { display: flex; gap: 15px; margin-bottom: 20px; }
  .card { border: 1px solid #ddd; padding: 15px; border-radius: 8px; flex: 1; }
  h4 { margin: 0 0 10px 0; color: #333; }
  .sale { color: #dc2626; font-weight: bold; }
  .in-stock { color: #16a34a; font-size: 0.85rem; font-weight: bold;}
  .out-stock { color: #94a3b8; font-size: 0.85rem; }
  
  .status { color: #16a34a; font-weight: bold; }
  .account-badge { background: #e2e8f0; padding: 8px 12px; border-radius: 6px; display: inline-block; margin-bottom: 15px; }
  a { color: #2563eb; text-decoration: none; }
  li { margin-bottom: 5px; color: #0284c7; font-weight: bold; }
  hr { margin: 40px 0; border: 0; border-top: 1px solid #cbd5e1; }
</style>
